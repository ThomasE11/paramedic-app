  {
    "skillName": "Prediction of difficult bag valve mask ventilations",
    "steps": [
      {
        "id": "bvm_pred_1",
        "stepNumber": 1,
        "title": "B – Beard and other mask seal issues",
        "description": "Student examines patient and reports on finding on a thick beard or facial pathology (i.e. trauma) that may create difficulty when obtaining an adequate seal.",
        "isRequired": true,
        "keyPoints": [
          "Examine for thick beard",
          "Check for facial jewelry",
          "Assess facial trauma or pathology",
          "Identify potential seal issues"
        ],
        "timeEstimate": 2,
        "isCritical": true
      },
      {
        "id": "bvm_pred_2",
        "stepNumber": 2,
        "title": "O – Obesity assessment",
        "description": "Student examines patient and reports on finding the patient's obese state may have the potential to decrease chest wall compliance, decreased ability to extend the head, and redundant soft tissue in pharynx.",
        "isRequired": true,
        "keyPoints": [
          "Assess patient's body habitus",
          "Evaluate chest wall compliance",
          "Check head extension capability",
          "Identify redundant soft tissue"
        ],
        "timeEstimate": 2,
        "isCritical": true
      },
      {
        "id": "bvm_pred_3",
        "stepNumber": 3,
        "title": "O – Old (>55 years) assessment",
        "description": "Student examines patient and reports on finding that the patients age may affect the range of motion of the neck and temporo-mandibular joint, associated loss soft tissue elasticity that affect the architecture of the mouth.",
        "isRequired": true,
        "keyPoints": [
          "Assess patient age (>55 years)",
          "Check neck range of motion",
          "Evaluate temporo-mandibular joint",
          "Assess soft tissue elasticity"
        ],
        "timeEstimate": 2,
        "isCritical": true
      },
      {
        "id": "bvm_pred_4",
        "stepNumber": 4,
        "title": "T – Toothless assessment",
        "description": "Student examines patient and reports on finding that missing teeth may affect the facial architecture causing tissue collapse around the corners of the mouth.",
        "isRequired": true,
        "keyPoints": [
          "Check for missing teeth",
          "Assess facial architecture",
          "Identify tissue collapse",
          "Evaluate mouth seal potential"
        ],
        "timeEstimate": 2,
        "isCritical": true
      },
      {
        "id": "bvm_pred_5",
        "stepNumber": 5,
        "title": "S – Sounds assessment",
        "description": "Student examines patient and reports on finding that he hears snoring or stridor which may be associated with abnormal upper and lower airway sounds.",
        "isRequired": true,
        "keyPoints": [
          "Listen for snoring",
          "Identify stridor",
          "Assess upper airway sounds",
          "Evaluate lower airway sounds"
        ],
        "timeEstimate": 2,
        "isCritical": true
      }
    ]
  },
