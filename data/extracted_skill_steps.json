        "keyPoints": [
          "Place heel of hand on lower half of breastbone",
          "Compress at least 2 inches deep",
          "Rate of 100-120 compressions per minute",
          "Allow complete chest recoil",
          "Minimize interruptions"
        ],
        "timeEstimate": 2,
        "isCritical": true
      },
      {
        "id": "cpr_6",
        "stepNumber": 6,
        "title": "Attach Defibrillator",
        "description": "Apply defibrillator pads and analyze rhythm",
        "isRequired": true,
        "keyPoints": [
          "Turn on defibrillator",
          "Apply pads to bare chest",
          "Ensure proper pad placement",
          "Clear patient for analysis",
          "Follow device prompts"
        ],
        "timeEstimate": 2,
        "isCritical": true
      }
