# ============================================================================
# ParaMedic Studio — Environment Variables
# ============================================================================
# Copy this file to `.env.local` and fill in real values. Only variables
# prefixed with `VITE_` are exposed to the browser.
#
# DO NOT put service-role keys, database passwords, or any other secrets
# here — anything in a VITE_ variable is shipped in the client bundle.
# ============================================================================

# Supabase — classroom multiplayer (Phase 4)
# Anon key is public-safe; RLS enforces per-row access on the server side.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
