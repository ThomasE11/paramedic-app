generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                  String         @id @default(cuid())
  name                String?
  email               String         @unique
  emailVerified       DateTime?      @map("email_verified")
  image               String?
  password            String?
  role                String         @default("instructor")
  bio                 String?
  createdAt           DateTime       @default(now()) @map("created_at")
  department          String?
  phone               String?
  preferences         Json?          @default("{}")
  title               String?
  updatedAt           DateTime       @default(now()) @updatedAt @map("updated_at")
  accounts            Account[]
  attendanceMarked    Attendance[]
  classSessions       ClassSession[]
  notes               Note[]
  sessions            Session[]
  createdAssignments  Assignment[]   @relation("AssignmentCreator")
  createdRubrics      Rubric[]       @relation("RubricCreator")
  uploadedSubmissions Submission[]   @relation("SubmissionUploader")

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Module {
  id                 String                @id @default(cuid())
  code               String                @unique
  name               String
  description        String?
  submissionSchedule Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  averageGPA         Float?                @default(0.0)
  totalCredits       Int?                  @default(0)
  assignments        Assignment[]          @relation("ModuleAssignments")
  classSessions      ClassSession[]
  grades             Grade[]
  students           Student[]
  subjects           Subject[]
  activities         ModuleActivity[]
  placements         PlacementAssignment[]

  @@map("modules")
}

model Student {
  id                  String                @id @default(cuid())
  studentId           String                @unique
  firstName           String
  lastName            String
  fullName            String
  email               String                @unique
  phone               String?
  moduleId            String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  creditHours         Int?                  @default(0)
  currentGPA          Float?                @default(0.0)
  activities          Activity[]
  attendance          Attendance[]
  grades              Grade[]
  notes               Note[]
  conflicts           ScheduleConflict[]
  schedules           Schedule[]
  module              Module?               @relation(fields: [moduleId], references: [id])
  submissions         Submission[]          @relation("StudentSubmissions")
  emailLogs           EmailLog[]
  placements          PlacementAssignment[]
  siteVisitNotes      SiteVisitNote[]
  recordOfDiscussions RecordOfDiscussion[]

  @@map("students")
}

model Note {
  id        String   @id @default(cuid())
  studentId String
  userId    String
  title     String
  content   String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Activity {
  id          String   @id @default(cuid())
  studentId   String?
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())
  student     Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model TimeSlot {
  id              String          @id @default(cuid())
  startTime       String
  endTime         String
  duration        Int
  createdAt       DateTime        @default(now())
  scheduleEntries ScheduleEntry[]

  @@map("time_slots")
}

model Location {
  id              String          @id @default(cuid())
  name            String
  capacity        Int?
  type            String          @default("classroom")
  building        String?
  floor           String?
  equipment       String?
  createdAt       DateTime        @default(now())
  classSessions   ClassSession[]
  scheduleEntries ScheduleEntry[]

  @@map("locations")
}

model Subject {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  description     String?
  credits         Int?
  moduleId        String?
  createdAt       DateTime        @default(now())
  classSessions   ClassSession[]
  grades          Grade[]
  scheduleEntries ScheduleEntry[]
  module          Module?         @relation(fields: [moduleId], references: [id])

  @@map("subjects")
}

model Schedule {
  id           String          @id @default(cuid())
  studentId    String
  semester     String          @default("current")
  academicYear String          @default("2024-2025")
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  entries      ScheduleEntry[]
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, semester, academicYear])
  @@map("schedules")
}

model ScheduleEntry {
  id          String    @id @default(cuid())
  scheduleId  String
  subjectId   String?
  timeSlotId  String
  locationId  String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  title       String
  type        String    @default("class")
  instructor  String?
  notes       String?
  color       String?   @default("#3B82F6")
  isRecurring Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  location    Location? @relation(fields: [locationId], references: [id])
  schedule    Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  subject     Subject?  @relation(fields: [subjectId], references: [id])
  timeSlot    TimeSlot  @relation(fields: [timeSlotId], references: [id])

  @@map("schedule_entries")
}

model ScheduleConflict {
  id           String   @id @default(cuid())
  studentId    String
  entryId1     String
  entryId2     String
  conflictType String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("schedule_conflicts")
}

model Grade {
  id           String    @id @default(cuid())
  studentId    String
  subjectId    String
  moduleId     String?
  grade        String
  gradePoints  Float
  creditHours  Int       @default(3)
  semester     String    @default("current")
  academicYear String    @default("2024-2025")
  examType     String?
  examDate     DateTime?
  comments     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  module       Module?   @relation(fields: [moduleId], references: [id])
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, semester, academicYear, examType])
  @@map("grades")
}

model ClassSession {
  id               String       @id @default(cuid())
  title            String
  description      String?
  subjectId        String?
  moduleId         String?
  locationId       String?
  instructorId     String?
  date             DateTime
  startTime        String
  endTime          String
  duration         Int
  type             String       @default("lecture")
  status           String       @default("scheduled")
  capacity         Int?         @default(30)
  notes            String?
  color            String?      @default("#3B82F6")
  isRecurring      Boolean      @default(false)
  recurringPattern String?
  recurringEndDate DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  attendance       Attendance[]
  instructor       User?        @relation(fields: [instructorId], references: [id])
  location         Location?    @relation(fields: [locationId], references: [id])
  module           Module?      @relation(fields: [moduleId], references: [id])
  subject          Subject?     @relation(fields: [subjectId], references: [id])

  @@map("class_sessions")
}

model Attendance {
  id             String       @id @default(cuid())
  classSessionId String
  studentId      String
  status         String       @default("present")
  notes          String?
  markedAt       DateTime?
  markedBy       String?
  duration       Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  classSession   ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  marker         User?        @relation(fields: [markedBy], references: [id])
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@map("attendance")
}

model Assignment {
  id                String       @id @default(cuid())
  title             String
  description       String?
  type              String       @default("case_reflection")
  moduleId          String
  subjectId         String?
  createdBy         String
  dueDate           DateTime?
  maxScore          Int          @default(100)
  isActive          Boolean      @default(true)
  allowResubmission Boolean      @default(false)
  autoEvaluate      Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  creator           User         @relation("AssignmentCreator", fields: [createdBy], references: [id])
  module            Module       @relation("ModuleAssignments", fields: [moduleId], references: [id], onDelete: Cascade)
  rubrics           Rubric[]
  submissions       Submission[]

  @@map("assignments")
}

model Rubric {
  id            String       @id @default(cuid())
  assignmentId  String
  title         String
  description   String?
  version       Int          @default(1)
  criteria      Json
  fileName      String?
  filePath      String?
  fileSize      Int?
  mimeType      String?
  extractedText String?      @db.Text
  isActive      Boolean      @default(true)
  createdBy     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  assignment    Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  creator       User         @relation("RubricCreator", fields: [createdBy], references: [id])
  evaluations   Evaluation[]

  @@map("rubrics")
}

model Submission {
  id            String       @id @default(cuid())
  assignmentId  String
  studentId     String
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  extractedText String?      @db.Text
  status        String       @default("submitted")
  submittedAt   DateTime     @default(now())
  uploadedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  assignment    Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       Student      @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  uploader      User?        @relation("SubmissionUploader", fields: [uploadedBy], references: [id])
  evaluations   Evaluation[]

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

model Evaluation {
  id             String     @id @default(cuid())
  submissionId   String
  rubricId       String
  totalScore     Float
  maxScore       Float
  percentage     Float
  feedback       String     @db.Text
  criteriaScores Json
  strengths      String?    @db.Text
  improvements   String?    @db.Text
  evaluatedBy    String     @default("ai")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  rubric         Rubric     @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, rubricId])
  @@map("evaluations")
}

model ModuleActivity {
  id             String   @id @default(cuid())
  moduleId       String
  title          String
  activityType   String   @default("seminar")
  date           DateTime
  duration       Int?
  targetAudience String?
  description    String?  @db.Text
  content        Json?
  objectives     String[] @default([])
  outcomes       String?  @db.Text
  facilitator    String?
  location       String?
  studentCount   Int?
  attachments    Json?
  notes          String?  @db.Text
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  module         Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId, date])
  @@index([activityType])
  @@map("module_activities")
}

model EmailLog {
  id             String   @id @default(cuid())
  studentId      String?
  recipientEmail String
  recipientName  String
  subject        String
  body           String   @db.Text
  sentBy         String
  moduleCode     String?
  status         String   @default("sent")
  emailType      String   @default("general")
  sentAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, sentAt])
  @@index([sentBy, sentAt])
  @@index([moduleCode, sentAt])
  @@map("email_logs")
}

model PlacementSite {
  id             String                @id @default(cuid())
  name           String
  type           String                @default("hospital")
  address        String?
  city           String?
  contactPerson  String?
  contactEmail   String?
  contactPhone   String?
  capacity       Int?
  department     String?
  specialization String?
  facilities     Json?
  notes          String?               @db.Text
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  assignments    PlacementAssignment[]
  visits         SiteVisit[]

  @@index([type, isActive])
  @@map("placement_sites")
}

model PlacementAssignment {
  id           String        @id @default(cuid())
  studentId    String
  siteId       String
  moduleId     String?
  startDate    DateTime
  endDate      DateTime
  weekNumber   Int?
  rotationType String        @default("clinical")
  shift        String?
  mentor       String?
  objectives   String[]      @default([])
  status       String        @default("scheduled")
  notes        String?       @db.Text
  createdBy    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  site         PlacementSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  module       Module?       @relation(fields: [moduleId], references: [id])

  @@index([studentId, startDate])
  @@index([siteId, startDate])
  @@index([status])
  @@map("placement_assignments")
}

model SiteVisit {
  id               String    @id @default(cuid())
  siteId           String
  visitDate        DateTime
  visitTime        String?
  visitedBy        String
  purpose          String?
  duration         Int?
  generalNotes     String?   @db.Text
  mentorFeedback   String?   @db.Text
  areasOfConcern   String?   @db.Text
  recommendations  String?   @db.Text
  followUpRequired Boolean   @default(false)
  followUpDate     DateTime?
  attachments      Json?

  // Signatures
  instructorSignature     String?   @db.Text
  instructorSignatureDate DateTime?
  instructorName          String?
  studentSignature        String?   @db.Text
  studentSignatureDate    DateTime?

  // Form status
  status      String    @default("draft") // draft, completed, archived
  completedAt DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  site         PlacementSite   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  studentNotes SiteVisitNote[]

  @@index([siteId, visitDate])
  @@index([visitedBy, visitDate])
  @@index([status, completedAt])
  @@map("site_visits")
}

model SiteVisitNote {
  id                  String    @id @default(cuid())
  visitId             String
  studentId           String
  performance         String?
  competencies        Json?
  strengths           String?   @db.Text
  areasForDevelopment String?   @db.Text
  mentorComments      String?   @db.Text
  studentReflection   String?   @db.Text
  grade               String?
  skillsAssessed      String[]  @default([])
  attendanceStatus    String    @default("present")
  hoursCompleted      Float?
  concerns            String?   @db.Text
  actionItems         String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  visit               SiteVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  student             Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([visitId, studentId])
  @@index([studentId, createdAt])
  @@map("site_visit_notes")
}

model RecordOfDiscussion {
  id                  String   @id @default(cuid())
  studentId           String
  discussionDate      DateTime
  discussionTime      String
  companyNameLocation String
  conductorName       String
  conductorRole       String   @default("HCT Mentor")

  // Record of Discussion Fields
  peoplePresent     String? @db.Text
  discussedTopics   String? @db.Text
  studentActions    String? @db.Text
  evidenceAvailable String? @db.Text

  // Follow-up Meeting
  followUpAttendance String? @db.Text
  attendanceRecorded Boolean @default(false)
  attendanceSessions Int?    @default(0)

  // Challenges at Hospital
  challengesEncountered String? @db.Text

  // Interesting Cases
  interestingCases String? @db.Text

  // Skills Completed
  skillsCompleted Json?

  // Discussion on SA2 Assessment
  sa2Discussion String? @db.Text

  // Assessment Criteria Met
  assessmentCriteriaMet String? @db.Text

  // Signatures
  conductorSignature     String?   @db.Text
  conductorSignatureDate DateTime?
  studentSignature       String?   @db.Text
  studentSignatureDate   DateTime?

  // Metadata
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, discussionDate])
  @@index([createdBy, discussionDate])
  @@map("record_of_discussions")
}
